# ── Supabase (frontend) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (Vercel serverless / webhook) ────────────────────────────────────
# Same URL as above (no VITE_ prefix — not exposed to browser)
SUPABASE_URL=https://your-project.supabase.co
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
